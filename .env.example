# PI Scam Shield — Environment Variables
# Copy this file to .env and fill in your values before starting the server.

# ── Required ──────────────────────────────────────────────────────────────────

# Discord webhook URL — reports are delivered here.
# How to get one:
#   Discord server → Server Settings → Integrations → Webhooks → New Webhook
#   Choose a channel (e.g. #scam-reports), copy the URL, paste it below.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Pi Server API Key — required for Pi Browser donations.
# Get this from your Pi Developer Portal project settings.
PI_SERVER_API_KEY=YOUR_PI_SERVER_API_KEY

# ── Optional ──────────────────────────────────────────────────────────────────

# Port the server listens on (default: 3000)
PORT=3000

# Set to "true" ONLY for local desktop testing.
# In production (deployed, opened in PI Browser) this MUST be "false".
SANDBOX=false
