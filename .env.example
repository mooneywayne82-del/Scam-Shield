# PI Scam Shield — Environment Variables
# Copy this file to .env and fill in your values before starting the server.

# ── Required ──────────────────────────────────────────────────────────────────

# Discord webhook URL — reports are delivered here.
# How to get one:
#   Discord server → Server Settings → Integrations → Webhooks → New Webhook
#   Choose a channel (e.g. #scam-reports), copy the URL, paste it below.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Pi Server API Key — required for Pi Browser donations.
# Get this from your Pi Developer Portal project settings.
PI_SERVER_API_KEY=YOUR_PI_SERVER_API_KEY

# Set to "true" to turn off donation approve/complete while keeping PI_SERVER_API_KEY set (e.g. testing).
# DISABLE_PI_DONATIONS=false

# Use npm package pi-backend (same as https://github.com/pi-apps/pi-nodejs) for getPayment + completePayment on donation routes.
# PiNetwork() still requires your app wallet secret key (S..., 56 chars) even if you only complete U2A donations — library requirement.
# USE_PI_BACKEND_SDK=false
# PI_APP_WALLET_PRIVATE_SEED=

# DANGEROUS / testing only: full README flow createPayment → submitPayment → completePayment (pays Pi FROM your app wallet TO uid).
# Requires USE_PI_BACKEND_SDK=true, PI_A2U_README_FLOW_TEST=true, PI_A2U_README_FLOW_TEST_SECRET=long-random, and header X-Pi-A2u-Test-Secret on POST /api/dev/pi-backend-a2u-readme-flow
# PI_A2U_README_FLOW_TEST=false
# PI_A2U_README_FLOW_TEST_SECRET=

# Pi Platform API base URL (no trailing /v2). Default: https://api.minepi.com
# PI_PLATFORM_API_URL=https://api.minepi.com

# ── Optional ──────────────────────────────────────────────────────────────────

# Port the server listens on (default: 3000)
PORT=3000

# Session secret for express-session (required in production).
# Use a long random value.
SESSION_SECRET=replace_with_a_long_random_secret

# If running behind a reverse proxy (Render, Railway, Nginx), set true.
TRUST_PROXY=true

# MongoDB for persistent donation payment state (recommended for production)
MONGO_URI=mongodb+srv://YOUR_DB_USER:YOUR_DB_PASSWORD@cluster0.example.mongodb.net/scam_shield?retryWrites=true&w=majority&appName=Cluster0
MONGO_DB_NAME=scam_shield
MONGO_PAYMENTS_COLLECTION=donation_payments
# If Atlas TLS fails on your host (e.g. opaque SSL errors), try MONGO_DNS_LOOKUP_FAMILY=4 or 6 (Render defaults to 4 when RENDER=true in server).
# MONGO_DNS_LOOKUP_FAMILY=

# Set to "true" ONLY for local desktop testing.
# In production (deployed, opened in PI Browser) this MUST be "false".
SANDBOX=false

# Set to "true" to use Pi-only login (skip backend /api/user/signin at login).
# This mirrors simple client-auth flows and helps isolate backend sign-in issues.
# Keep "false" for the stricter default server-verified login session flow.
PI_ONLY_LOGIN=false

# Obtain the following 2 values on the Pi Developer Portal: 

# Domain Validation Key:
DOMAIN_VALIDATION_KEY=YOUR_DOMAIN_VALIDATION_KEY
# PI Platform API Key:
PI_API_KEY=YOUR_PI_PLATFORM_API_KEY